{
  "name": "kilroy",
  "version": "0.1.0",
  "description": "Tribal knowledge for coding agents",
  "type": "module",
  "bin": {
    "kilroy": "src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run dev:server & bun run dev:web & wait",
    "dev:server": "bun run --hot src/server.ts",
    "dev:web": "cd web && bunx vite",
    "start": "bun run src/server.ts",
    "build:web": "cd web && bun run build",
    "test": "bun test --cwd . test/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.39.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.0"
  }
}
