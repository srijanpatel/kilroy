# Required: random secret for signing sessions and JWTs.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Public URL where your Kilroy is reachable — used for OAuth callbacks and
# MCP audiences. Set this if you're behind a reverse proxy or using a custom
# domain. If unset, defaults to http://localhost:${KILROY_PORT}.
# KILROY_URL=https://kilroy.sh

# Port the server listens on internally. Default: 7432. This is separate
# from KILROY_URL — a reverse proxy usually forwards a public URL (no port)
# to this internal port. Only shows up in the URL when KILROY_URL is unset.
# If you change this, also update the port mapping in docker-compose.yml.
# KILROY_PORT=7432

# Pin a specific Kilroy version. Default: the tag baked into docker-compose.yml.
# KILROY_REF=v0.16.0

# Disable email+password login. Default: true (enabled).
# Set to "false" on instances that should require OAuth only.
# KILROY_EMAIL_PASSWORD=false

# OAuth providers (optional) — enable GitHub/Google login for humans.
# A social button only appears if BOTH id and secret are set for that provider.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
